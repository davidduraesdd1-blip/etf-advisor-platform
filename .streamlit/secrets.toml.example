# Streamlit Cloud secrets — EXAMPLE / TEMPLATE
#
# Copy this block into Streamlit Cloud → App settings → Secrets.
# DO NOT commit a real secrets.toml with live values — only this
# .example file is committed.
#
# How these reach the app: Streamlit Cloud populates st.secrets AND
# os.environ with every entry on app boot. config.py reads via
# os.environ.get(...) so the same code path works locally (.env) and
# on Cloud (this file).

# Required for the EDGAR daily_scanner to run. SEC policy demands an
# identifiable contact email in the User-Agent of every programmatic
# request. Runtime guard raises RuntimeError if this is still the
# placeholder.
EDGAR_CONTACT_EMAIL = "ops@your-domain.example"

# Optional — upgrade-path price sources. If unset, data_feeds falls
# back to yfinance → Stooq and skips Alpha Vantage.
# ALPHA_VANTAGE_API_KEY = "YOUR_KEY_HERE"
# POLYGON_API_KEY = "YOUR_KEY_HERE"
# FINNHUB_API_KEY = "YOUR_KEY_HERE"

# Optional — observability. Leave unset for the demo.
# SENTRY_DSN = "https://...@sentry.io/..."

# Not needed for demo — uncomment when BROKER_PROVIDER flips to
# "alpaca_paper" or "alpaca".
# ALPACA_API_KEY = "YOUR_KEY_HERE"
# ALPACA_API_SECRET = "YOUR_SECRET_HERE"
# ALPACA_BASE_URL = "https://paper-api.alpaca.markets"
