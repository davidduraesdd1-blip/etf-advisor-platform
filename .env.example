# ETF Advisor Platform — Environment Variables (example)
# Copy to .env (local) or set in Streamlit Cloud Secrets UI (prod).
# .env is gitignored. Never commit real keys.

# ── Data sources (all optional for demo mode) ────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_api_key_here
POLYGON_API_KEY=your_api_key_here
ETFCOM_API_KEY=your_api_key_here
FINNHUB_API_KEY=your_api_key_here

# ── Broker integration (post-demo) ───────────────────────────────────────────
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Observability (optional) ─────────────────────────────────────────────────
SENTRY_DSN=your_api_key_here
